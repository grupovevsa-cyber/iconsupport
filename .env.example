# Variables de entorno para ICON Support
# Copia este archivo como .env y rellena con tus credenciales de Supabase

# ── Supabase ──────────────────────────────────────────────────────────
# Obtén estos valores en: https://app.supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica-aqui

# ── App ───────────────────────────────────────────────────────────────
# URL base de la aplicación (para generar los QR codes)
# En desarrollo: http://localhost:3000
# En producción: https://tu-app.vercel.app
VITE_APP_URL=http://localhost:3000

# ── Empresa (para encabezado del PDF) ────────────────────────────────
VITE_EMPRESA_NOMBRE=ICON Support
VITE_EMPRESA_RIF=J-12345678-9
VITE_EMPRESA_TELEFONO=+1 (555) 000-0000
VITE_EMPRESA_EMAIL=soporte@iconsupport.com
VITE_EMPRESA_DIRECCION=Av. Principal, Edificio Tech, Piso 2
